# Copy to .env and fill in values:
#   cp .env.example .env        (Linux / macOS)
#   copy .env.example .env      (Windows)

# MongoDB (remote assessment database — required for ingest and agent drill-down)
MONGODB_URL=mongodb+srv://USER:PASSWORD@HOST/convi-assessment

# Anthropic (required for graphAgent)
API_KEY_ANTHROPIC=
# Optional model override (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Neo4j — local Desktop, Docker (see docker-compose.yml), or Aura cloud
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# If using docker-compose.yml as shipped, use:
# NEO4J_PASSWORD=convi-dev-password
